CMC_API_KEY=
CMC_BASE_URL=https://pro-api.coinmarketcap.com

# CMC Agent Hub MCP uses the same API key via X-CMC-MCP-API-KEY.

# Track 1 live execution. Keep this pointed at dry-run/testnet until the full
# loop has passed rehearsal.
TWAK_CLI=npx @trustwallet/cli
TWAK_DRY_RUN=true
TWAK_CHAIN=bsc
TWAK_STABLE_SYMBOL=USDT
TWAK_SLIPPAGE_PERCENT=1
TWAK_QUOTE_ONLY=true
TWAK_WALLET_ADDRESS=
PANCAKESWAP_ROUTER_ADDRESS=

# TWAK setup/authentication.
TWAK_API_KEY=
TWAK_API_SECRET=
TWAK_WALLET_PASSWORD=

# Optional BNB Agent SDK identity registration.
NETWORK=bsc-testnet
WALLET_PASSWORD=
PRIVATE_KEY=
WALLET_ADDRESS=
ERC8183_AGENT_URL=
ERC8183_SERVICE_PRICE=1000000000000000000

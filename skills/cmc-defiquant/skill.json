{
  "name": "defiquant-alpha-pool-risk",
  "version": "0.1.0",
  "description": "CMC-driven BNB Chain alpha pool strategy with regime-aware long/short research lanes and drawdown-aware risk controls.",
  "track": "coinmarketcap-skill",
  "license": "MIT",
  "tags": [
    "coinmarketcap",
    "bnb-chain",
    "strategy",
    "regime",
    "long-short-research",
    "risk",
    "non-executing"
  ],
  "entrypoint": {
    "command": "python",
    "args": ["-m", "defiquant.cli", "signal", "--config", "configs/strategy.json"]
  },
  "inputs": {
    "universe": "CMC-listed BNB Chain token symbols",
    "ohlcv": "Historical OHLCV candles"
  },
  "outputs": {
    "signals": "Target weights with score rationale",
    "regime_strategy": "Non-executing up-channel long-bias and down-channel short-bias strategy spec",
    "delta_neutral_lab": "Non-executing delta-neutral long/short basket walk-forward report",
    "risk": "Cash reserve and drawdown guardrail state"
  },
  "execution": "disabled",
  "examples": {
    "input": "examples/input.fixture.json",
    "output": "examples/output.fixture.json",
    "regime_output": "examples/regime-output.fixture.json",
    "delta_neutral_output": "examples/delta-neutral-output.fixture.json"
  },
  "safety": {
    "execution": "disabled",
    "wallet_access": "none",
    "twak_access": "none",
    "private_key_access": "none",
    "mutation": "read-only analysis"
  }
}
